{{ 'shop-category.css' | asset_url | stylesheet_tag }}

<section class="shop-category">

  <div class="page-width">

    <h2 class="shop-category__heading">
      {{ section.settings.heading }}
    </h2>

    <div class="shop-category__wrapper">

      {% for block in section.blocks %}

        <div class="shop-category__card">

          <div class="shop-category__image">

            {{ block.settings.category_image
 | image_url: width: 800  
 | image_tag
            }}

          </div>

          <a href="{{ block.settings.button_link }}" class="shop-category__button">
            <span>
              {{ block.settings.button_text }}
            </span>

            <img
              src="{{ 'arrow-icon.svg' | asset_url }}"
              alt="Arrow Icon"
              width= "7"
              height="14">
          </a>

        </div>

      {% endfor %}

    </div>

  </div>

</section>

{% schema %}
  {
    "name": "Shop Category",

    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Section Heading",
        "default": "Shop by category"
      }
    ],

    "blocks": [
      {
        "type": "category",
        "name": "Category Card",

        "settings": [
          {
            "type": "image_picker",
            "id": "category_image",
            "label": "Category Image"
          }, {
            "type": "text",
            "id": "button_text",
            "label": "Button Text",
            "default": "Shop Blankets"
          }, {
            "type": "url",
            "id": "button_link",
            "label": "Button Link"
          }
        ]
      }
    ],

    "presets": [
      {
        "name": "Shop Category"
      }
    ]
  }
{% endschema %}