{{ 'product-highlight.css' | asset_url | stylesheet_tag }}

<section class="product-highlight">

  <div class="page-width">

    <div class="product-highlight__wrapper">

      <!-- LEFT CONTENT -->

      <div class="product-highlight__content">

        <h2 class="product-highlight__title">
          {{ section.settings.heading }}
        </h2>

        <div class="product-highlight__rating">
          ★★★★★
          <span>4.7</span>
        </div>

        <p class="product-highlight__description">
          {{ section.settings.description }}
        </p>

        <!-- SIZE -->

        <div class="product-highlight__field">

          <label>Size</label>

          <select>
            <option>Small ( 100cm * 180cm ) </option>
            <option>Double ( 150cm x 200 CM ) & King (200 CM x 240 CM)</option>
            <option>Single ( 100cm * 150cm )</option>
          </select>

        </div>

        <!-- QUANTITY -->

        <div class="product-highlight__field">

          <label>Quantity</label>

          <div class="quantity-box">

            <button>-</button>

            <span>3</span>

            <button>+</button>

          </div>

        </div>

        <!-- COLOR -->

        <div class="product-highlight__field">

          <label>Color</label>

          <select>
            <option>Creamy</option>
          </select>

        </div>

        <!-- BUTTON -->

        <a href="#" class="product-highlight__button">
          Customize now
        </a>

      </div>

      <!-- RIGHT IMAGES -->

      <div class="product-highlight__gallery">

        <div class="product-highlight__main-image">

          {{ section.settings.main_image
 | image_url: width: 700
 | image_tag
          }}

        </div>

        <div class="product-highlight__thumbnails">

          {% for block in section.blocks %}

            <div class="product-highlight__thumb">

              {{ block.settings.thumbnail
 | image_url: width: 120
 | image_tag
              }}

            </div>

          {% endfor %}

        </div>

      </div>

    </div>

  </div>

</section>

{% schema %}
  {
    "name": "Product Highlight",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Kozyful Blanket"
      }, {
        "type": "textarea",
        "id": "description",
        "label": "Description",
        "default": "Fleece blankets are available in Single (100 CM x 150 CM), Double (150 CM x 200 CM) & King (200 CM x 240 CM). The flannel top is 220 GSM. 100% microfiber polyester. The Sherpa reverse is 260 GSM."
      }, {
        "type": "image_picker",
        "id": "main_image",
        "label": "Main Image"
      }, {
        "type": "number",
        "id": "rating",
        "label": "Rating",
        "default": 4.7
      }
    ],
    "blocks": [
      {
        "type": "thumbnail",
        "name": "Thumbnail",
        "settings": [
          {
            "type": "image_picker",
            "id": "thumbnail",
            "label": "Thumbnail Image"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Product Highlight"
      }
    ]
  }
{% endschema %}