<section
  id="custom-hero-{{ section.id }}"
  class="custom-hero"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    background-color: {{ section.settings.background_color }};
    text-align: {{ section.settings.content_alignment }};
  ">
  <div class="page-width">

    {% if section.settings.heading != blank %}
      <h1 class="custom-hero__heading">
        {{ section.settings.heading }}
      </h1>
    {% endif %}

    {% if section.settings.description != blank %}
      <p class="custom-hero__description">
        {{ section.settings.description }}
      </p>
    {% endif %}

    {% if section.settings.content != blank %}
      <div class="custom-hero__content rte">
        {{ section.settings.content }}
      </div>
    {% endif %}

    {% if section.settings.image != blank %}
      <div class="custom-hero__image">
        {{ section.settings.image
 | image_url: width: 1200
 | image_tag:
 loading: 'lazy',
 alt: section.settings.heading
        }}
      </div>
    {% endif %}

    {% if section.settings.video != blank %}
      <div class="custom-hero__video">
        {{ section.settings.video
 | video_tag:
 autoplay: false,
 loop: true,
 muted: false,
 controls: true
        }}
      </div>
    {% endif %}

    {% if section.settings.show_button and section.settings.button_link != blank %}
      <div class="custom-hero__button">
        <a href="{{ section.settings.button_link }}" class="button">
          Shop Now
        </a>
      </div>
    {% endif %}

    {% assign featured_product = all_products[section.settings.featured_product] %}

    {% if featured_product != blank %}
      <div class="custom-hero__product">
        <h3>Featured Product</h3>

        <p>{{ featured_product.title }}</p>

        {% if featured_product.featured_image %}
          {{ featured_product.featured_image
 | image_url: width: 400
 | image_tag:
 loading: 'lazy',
 alt: featured_product.title
          }}
        {% endif %}

        <p>{{ featured_product.price | money }}</p>
      </div>
    {% endif %}

    {% assign featured_collection = collections[section.settings.collection] %}

    {% if featured_collection != blank %}
      <div class="custom-hero__collection">
        <h3>Featured Collection</h3>

        <p>{{ featured_collection.title }}</p>

        {% if featured_collection.featured_image %}
          {{ featured_collection.featured_image
 | image_url: width: 500
 | image_tag:
 loading: 'lazy',
 alt: featured_collection.title
          }}
        {% endif %}
      </div>
    {% endif %}

    {% for product in collection.products %}
      {% render 'product-card', product: product %}
    {% endfor %}

  </div>
</section>

{% schema %}
  {
    "name": "Custom Hero",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Welcome to our store"
      },
      {
        "type": "textarea",
        "id": "description",
        "label": "Description",
        "default": "This is my first Shopify section"
      },
      {
        "type": "richtext",
        "id": "content",
        "label": "Content",
        "default": "<p>Add your rich text content here.</p>"
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
      }, {
        "type": "video",
        "id": "video",
        "label": "Video"
      }, {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      }, {
        "type": "checkbox",
        "id": "show_button",
        "label": "Show Button",
        "default": true
      }, {
        "type": "range",
        "id": "padding_top",
        "label": "Top Padding",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "default": 40
      }, {
        "type": "select",
        "id": "content_alignment",
        "label": "Content Alignment",
        "options": [
          {
            "value": "left",
            "label": "Left"
          }, {
            "value": "center",
            "label": "Center"
          }, {
            "value": "right",
            "label": "Right"
          }
        ],
        "default": "left"
      }, {
        "type": "color",
        "id": "background_color",
        "label": "Background Color",
        "default": "#ffffff"
      }, {
        "type": "product",
        "id": "featured_product",
        "label": "Featured Product"
      }, {
        "type": "collection",
        "id": "collection",
        "label": "Featured Collection"
      }
    ],
    "presets": [
      {
        "name": "Custom Hero"
      }
    ]
  }
{% endschema %}